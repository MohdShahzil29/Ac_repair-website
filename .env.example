# =============================================================================
# LOCAL DEVELOPMENT — copy to .env.local
# =============================================================================

# Leave empty — Vite proxies /api to localhost backend
VITE_API_URL=

VITE_ADMIN_ID=admin
VITE_ADMIN_PASSWORD=change-this-password

ADMIN_ID=admin
ADMIN_PASSWORD=change-this-password
API_PORT=3001

# =============================================================================
# RENDER (backend API) — Environment tab on Render dashboard
# =============================================================================
# ADMIN_ID=admin
# ADMIN_PASSWORD=your-strong-password
# CORS_ORIGIN=https://your-app.vercel.app
#   (comma-separated if you have preview URLs too)
#   Example: https://ac-repair.vercel.app,https://ac-repair-git-main-user.vercel.app
# PORT is set automatically by Render — do not override

# =============================================================================
# VERCEL (frontend) — Project Settings → Environment Variables
# =============================================================================
# VITE_API_URL=https://your-service-name.onrender.com
#   (no trailing slash — your Render Web Service URL)
# VITE_ADMIN_ID=admin
# VITE_ADMIN_PASSWORD=your-strong-password
#   (must match ADMIN_PASSWORD on Render)
